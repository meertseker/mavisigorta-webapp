# Email Service (Resend)
RESEND_API_KEY=re_xxx
CONTACT_EMAIL=info@mavisigorta.net

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
NEXT_PUBLIC_META_PIXEL_ID=xxxxxxxxxxxxxxx

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=xxx

# SEO
NEXT_PUBLIC_GOOGLE_VERIFICATION=xxx
NEXT_PUBLIC_SITE_URL=https://tamamlayicisaglikbeylikduzu.com

# WhatsApp (digits-only with country code)
NEXT_PUBLIC_WA_NUMBER=905324807617

# ──────────────────────────────────────────────────────────────────
# Admin Panel (Supabase yok — geçici basit auth)
# ──────────────────────────────────────────────────────────────────
# Single admin user. Şifreyi düz metin olarak yazma; aşağıdaki komutla hash üret:
#   node -e "console.log(require('crypto').createHash('sha256').update('PAROLA' + 'SALT_DEĞERİ').digest('hex'))"
ADMIN_EMAIL=admin@mavisigorta.net
ADMIN_PASSWORD_HASH=__sha256_hex_of_password_plus_salt__
ADMIN_PASSWORD_SALT=__random_salt_string__
# 64+ char random hex; signed session cookie HMAC için kullanılır.
ADMIN_SESSION_SECRET=__random_64_char_secret__
# Saniye cinsinden oturum süresi (varsayılan 24sa).
ADMIN_SESSION_TTL=86400

# ──────────────────────────────────────────────────────────────────
# Google Ads API (https://developers.google.com/google-ads/api/docs/oauth/cloud-project)
# ──────────────────────────────────────────────────────────────────
# Manager (MCC) hesabından alınan developer token
GOOGLE_ADS_DEVELOPER_TOKEN=__developer_token__
# Google Cloud Console → OAuth2 Client (Desktop / Web application)
GOOGLE_ADS_CLIENT_ID=__client_id__.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=__client_secret__
# https://developers.google.com/google-ads/api/docs/oauth/client-library refresh token
GOOGLE_ADS_REFRESH_TOKEN=__refresh_token__
# Hedef hesap (rakamlar arasında tire YOK, ör: 1234567890)
GOOGLE_ADS_CUSTOMER_ID=__customer_id__
# Manager (MCC) hesabı kullanıyorsanız MCC ID; tek hesapsa boş bırakılabilir.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# v18 (varsayılan); periyodik olarak Google tarafından güncellenir.
GOOGLE_ADS_API_VERSION=v18
